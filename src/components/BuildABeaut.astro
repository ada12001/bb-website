---
// The signature scroll experience: assembles "The Beaut" layer-by-layer, then
// transitions into a horizontal menu rail (Cheesy Beaut, Hot Thigh) with a
// feathered floral wipe between items. Self-contained (markup + style + script).
---
<!-- BUILD + MENU RAIL (entered from the hero above) -->
<section class="build" id="build" data-nav-theme="dark">
  <div class="stage" id="stage">
    <div class="curtain" id="curtain"></div>
    <div class="bgword" id="bgword">BUN</div>
    <div class="scrim" id="scrim"></div>

    <ul class="recipe" id="recipe">
      <h4>Building the Beaut</h4>
      <li data-i="0"><span class="dot"></span>Toasted potato bun</li>
      <li data-i="1"><span class="dot"></span>All-natural fried chicken</li>
      <li data-i="2"><span class="dot"></span>Power of the pickles</li>
      <li data-i="3"><span class="dot"></span>Duke's mayo + top</li>
    </ul>

    <div class="sandwich" id="sandwich">
      <img class="layer l-tblower"  id="topBunLower"   src="/img/top-bun-lower.png"  alt="" />
      <img class="layer l-bottom"   id="bottomBun"     src="/img/bottom-bun.png"     alt="" />
      <img class="layer l-chshadow" id="chickenShadow" src="/img/chicken-shadow.png" alt="" />
      <img class="layer l-chicken"  id="chicken"       src="/img/chicken.png"        alt="Fried chicken" />
      <img class="layer l-pkshadow" id="picklesShadow" src="/img/pickles-shadow.png" alt="" />
      <img class="layer l-pickles"  id="pickles"       src="/img/pickles.png"        alt="Pickles" />
      <img class="layer l-tbupper"  id="topBunUpper"   src="/img/top-bun-upper.png"  alt="Potato bun" />
    </div>

    <div class="prail"><div class="fill" id="prailFill"></div></div>

    <div class="rcopy" id="rcopy0">
      <div class="rc-kicker">the original</div>
      <div class="rc-name">The Beaut</div>
      <div class="rc-desc">Crispy fried chicken, Duke's mayo &amp; house pickles on a toasted potato bun.</div>
      <div class="rc-price">8.49 <span>· combo +5.99</span></div>
      <a href="/order" class="rc-btn" data-order="the-beaut">Add to order</a>
    </div>

    <div class="rname" id="rname1">CHEESY BEAUT</div>
    <div class="rname" id="rname2">HOT THIGH</div>

    <div class="rimg" id="rimg1"><img src="/img/cheesy-beaut.png" alt="The Cheesy Beaut" /></div>
    <div class="rimg" id="rimg2"><img src="/img/hot-thigh.png" alt="Hot Thigh Sandwich" /></div>

    <div class="rcopy" id="rcopy1">
      <div class="rc-kicker">cheese, please</div>
      <div class="rc-name">The Cheesy Beaut</div>
      <div class="rc-desc">"The Beaut" plus baby Swiss. Same no-nonsense bird, now with a melt.</div>
      <div class="rc-price">9.99 <span>· combo +5.99</span></div>
      <a href="/order" class="rc-btn" data-order="cheesy-beaut">Add to order</a>
    </div>
    <div class="rcopy" id="rcopy2">
      <div class="rc-kicker">bring the heat</div>
      <div class="rc-name">Hot Thigh Sandwich</div>
      <div class="rc-desc">Juicy fried thigh, Beaut's hot sauce, Duke's mayo &amp; pickles on a potato bun.</div>
      <div class="rc-price">9.99 <span>· combo +5.99</span></div>
      <a href="/order" class="rc-btn" data-order="hot-thigh">Add to order</a>
    </div>
  </div>
</section>

<style is:global>
  /* ---------- Intro ---------- */
  .intro{
    height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;
    text-align:center;position:relative;
    background:radial-gradient(120% 90% at 50% -10%, var(--peach) 0%, var(--cream) 55%);
  }
  .intro .eyebrow{font-family:var(--font-script);color:var(--coral);font-size:clamp(26px,4vw,42px);margin-bottom:6px;transform:rotate(-3deg)}
  .intro h1{font-family:var(--font-display);font-size:clamp(54px,12vw,150px);line-height:.86;color:var(--navy);letter-spacing:.01em}
  .intro h1 .pop{color:var(--coral)}
  .intro p{margin-top:18px;max-width:520px;font-size:16px;color:var(--ink-soft);font-weight:500;padding:0 20px}
  .scrollcue{position:absolute;bottom:30px;left:50%;transform:translateX(-50%);font-size:11px;letter-spacing:.22em;text-transform:uppercase;font-weight:700;color:var(--navy);display:flex;flex-direction:column;align-items:center;gap:8px;opacity:.8}
  .scrollcue .arrow{width:1px;height:34px;background:var(--navy);transform-origin:top;animation:dripline 1.8s infinite}
  @keyframes dripline{0%{transform:scaleY(.3);transform-origin:top}50%{transform:scaleY(1);transform-origin:top}100%{transform:scaleY(.3);transform-origin:bottom}}

  /* ---------- Build + Menu-rail stage ---------- */
  .build{position:relative;height:900vh;background:var(--cream)}
  .stage{position:sticky;top:0;height:100vh;overflow:hidden;display:flex;align-items:center;justify-content:center}

  .bgword{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:var(--font-display);font-size:clamp(96px,25vw,360px);line-height:.8;color:var(--navy);opacity:.24;white-space:nowrap;pointer-events:none;text-align:center;letter-spacing:.02em;z-index:1;transition:color .25s linear}

  /* Soft panel-colored scrim over the left zone so the giant background word
     never bleeds under the copy. Sits just above the word, below food + copy.
     Width + gradient color are set per-frame in JS to match the live panel. */
  .scrim{position:absolute;left:0;top:0;bottom:0;z-index:2;pointer-events:none;width:0}
  @media(max-width:820px){ .scrim{display:none} }

  /* Below 820px the copy is hidden, so the food gets centered and can use more
     width than the two-column (48vw) cap above allows. */
  @media(max-width:820px){
    .sandwich{width:min(72vh,86vw)!important;height:min(72vh,86vw)!important}
    .rimg{width:min(78vh,90vw)!important;height:min(78vh,90vw)!important}
  }

  .sandwich{position:relative;width:min(84vh,680px,48vw);height:min(84vh,680px,48vw);z-index:5;filter:var(--shadow-food)}
  .sandwich{filter:drop-shadow(0 30px 30px rgba(60,30,20,.18))}
  .sandwich .layer{position:absolute;inset:0;width:100%;height:100%;object-fit:contain;will-change:transform,opacity}
  /* z-order front->back: Top_Bun_Upper > Pickles_Shadow > Pickles > Chicken_Shadow > Chicken > Bottom_Bun > Top_Bun_Lower */
  .l-tblower{z-index:1} .l-bottom{z-index:2} .l-chicken{z-index:3} .l-chshadow{z-index:4}
  .l-pickles{z-index:5} .l-pkshadow{z-index:6} .l-tbupper{z-index:7}

  .recipe{position:absolute;left:max(28px,4vw);top:50%;transform:translateY(-50%);z-index:20;width:clamp(260px,26vw,300px)}
  .recipe h4{font-family:var(--font-body);font-weight:700;text-transform:uppercase;letter-spacing:.14em;font-size:14px;color:var(--coral);margin-bottom:20px}
  .recipe li{list-style:none;display:flex;align-items:center;gap:14px;margin:18px 0;font-weight:600;font-size:21px;color:#b8afa3;transition:color .35s ease,transform .35s ease}
  .recipe li .dot{width:20px;height:20px;border-radius:50%;border:2px solid #cfc6ba;flex:0 0 auto;transition:all .35s ease;position:relative}
  .recipe li.on{color:var(--navy);transform:translateX(5px)}
  .recipe li.on .dot{background:var(--coral);border-color:var(--coral)}
  .recipe li.on .dot::after{content:"";position:absolute;left:5px;top:1px;width:6px;height:10px;border:solid #fff;border-width:0 2px 2px 0;transform:rotate(45deg)}
  @media(max-width:820px){ .recipe{display:none} }

  .prail{position:absolute;right:max(26px,3.5vw);top:50%;transform:translateY(-50%);height:200px;width:4px;background:rgba(30,35,73,.12);border-radius:4px;z-index:20}
  .prail .fill{position:absolute;top:0;left:0;width:100%;background:var(--coral);border-radius:4px;height:0%}
  @media(max-width:820px){ .prail{display:none} }


  /* ---------- Menu rail ---------- */
  .rname{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:var(--font-display);font-size:clamp(72px,18vw,280px);line-height:.8;white-space:nowrap;text-align:center;letter-spacing:.02em;z-index:1;opacity:0;pointer-events:none;will-change:transform,opacity}
  #rname1{color:var(--coral)} #rname2{color:var(--navy)}
  .rimg{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:min(92vh,760px,48vw);height:min(92vh,760px,48vw);z-index:5;opacity:0;will-change:transform,opacity;filter:drop-shadow(0 30px 30px rgba(45,25,15,.3))}
  .rimg img{width:100%;height:100%;object-fit:contain}
  .rcopy{position:absolute;left:max(28px,4vw);top:50%;transform:translateY(-50%);z-index:20;width:clamp(280px,28vw,400px);opacity:0;will-change:transform,opacity}
  .rcopy .rc-kicker{font-family:var(--font-script);font-size:clamp(30px,2.6vw,38px);color:var(--coral);margin-bottom:2px;transform:rotate(-2deg)}
  .rcopy .rc-name{font-family:var(--font-display);font-size:clamp(44px,3.8vw,58px);line-height:.92;color:var(--navy);margin-bottom:14px}
  .rcopy .rc-desc{font-size:clamp(16px,1.3vw,19px);font-weight:500;line-height:1.5;color:#4a463f;margin-bottom:20px}
  .rcopy .rc-price{font-weight:700;font-size:25px;color:var(--navy);margin-bottom:22px}
  .rcopy .rc-price span{font-weight:500;font-size:13px;color:#8a8478;text-transform:uppercase;letter-spacing:.06em}
  .rcopy .rc-btn{display:inline-block;background:var(--coral);color:#fff;border:none;border-radius:var(--radius-pill);cursor:pointer;font-family:var(--font-body);font-weight:700;text-transform:uppercase;letter-spacing:.08em;font-size:15px;padding:16px 34px;box-shadow:0 8px 20px rgba(240,83,72,.4)}
  #rcopy2 .rc-kicker{color:var(--navy)} #rcopy2 .rc-name{color:#fff} #rcopy2 .rc-desc{color:#ffe9e4}
  #rcopy2 .rc-price{color:#fff} #rcopy2 .rc-price span{color:#ffd6cf}
  #rcopy2 .rc-btn{background:var(--navy);box-shadow:0 8px 20px rgba(30,35,73,.4)}
  @media(max-width:820px){ .rcopy{display:none} }

  /* feathered floral wipe */
  .curtain{position:absolute;top:0;left:50%;height:100%;width:165vw;transform:translateX(-50%);z-index:50;opacity:0;pointer-events:none;background-repeat:repeat;background-position:center;background-size:440px auto;will-change:transform,opacity;-webkit-mask-image:linear-gradient(to right,transparent 0%,#000 17%,#000 83%,transparent 100%);mask-image:linear-gradient(to right,transparent 0%,#000 17%,#000 83%,transparent 100%)}
</style>

<script>
  // ---------- helpers ----------
  const clamp = (v: number, a: number, b: number) => Math.max(a, Math.min(b, v));
  const inv = (p: number, a: number, b: number) => clamp((p - a) / (b - a), 0, 1);
  const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
  const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);
  const easeIO = (t: number) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2);

  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const $ = (id: string) => document.getElementById(id)!;
  const build = $("build"), stage = $("stage"), bgword = $("bgword");
  const recipe = [...document.querySelectorAll<HTMLElement>("#recipe li")];
  const prail = $("prailFill"), curtain = $("curtain"), scrim = $("scrim");
  const topBunLower = $("topBunLower"), bottomBun = $("bottomBun"), chickenShadow = $("chickenShadow");
  const chicken = $("chicken"), picklesShadow = $("picklesShadow"), pickles = $("pickles"), topBunUpper = $("topBunUpper");
  const sandwichEl = $("sandwich"), recipeEl = $("recipe"), prailBox = document.querySelector<HTMLElement>(".prail")!;
  const railNames = [$("rname1"), $("rname2")];
  const railImgs = [$("rimg1"), $("rimg2")];
  const railCopy = [$("rcopy1"), $("rcopy2")];
  const beautCopy = $("rcopy0");

  const stages = [
    { to: 0.20, bg: "#faf4ea", word: "BUN" },
    { to: 0.44, bg: "#f7ece0", word: "CHICKEN" },
    { to: 0.66, bg: "#eef3ec", word: "PICKLES" },
    { to: 0.92, bg: "#f3ece3", word: "DUKE'S MAYO" },
    { to: 1.01, bg: "#f7e9df", word: "THE BEAUT" },
  ];

  const RAIL_START = 0.50;
  const PANELS = [[250, 244, 234], [160, 216, 209], [240, 83, 72]];
  const PARALLAX = reduce ? 1 : 0.6;       // 1 = no parallax differential
  const CURTAIN_MAX = reduce ? 0 : 0.28;   // hide the floral wash for reduced motion

  function railToPos(r: number) {
    if (r < 0.12) return 0;
    if (r < 0.44) return easeIO((r - 0.12) / 0.32);
    if (r < 0.56) return 1;
    if (r < 0.88) return 1 + easeIO((r - 0.56) / 0.32);
    return 2;
  }

  const CURTAINS: [number, number, string][] = [
    [0.12, 0.44, "/img/floral-peach.png"],
    [0.56, 0.88, "/img/floral-mint.png"],
  ];

  function render(P: number) {
    const aP = inv(P, 0, RAIL_START);
    const railOn = P > RAIL_START;
    const railP = inv(P, RAIL_START, 1);
    const pos = railToPos(railP);
    const vw = window.innerWidth;

    // ---- Responsive two-column rest layout ----
    // The copy (checklist / item cards) lives in a fixed LEFT zone. The food and the
    // giant background word are centered, so as the viewport narrows they'd slide left
    // into the copy. We shift them RIGHT by `restShift` to keep them clear of the copy,
    // and draw a panel-colored scrim over the left zone so the big word stays readable
    // behind the text. Below 820px the copy is hidden, so we center everything (shift 0).
    const copyVisible = vw > 820;
    const leftPad = Math.max(28, vw * 0.04);
    const copyW = Math.max(290, Math.min(400, vw * 0.28));
    const copyRight = leftPad + copyW;
    const gap = Math.max(72, vw * 0.05);
    const rightPad = Math.max(24, vw * 0.03);
    const restShift = copyVisible ? Math.max(0, (copyRight + gap + (vw - rightPad)) / 2 - vw / 2) : 0;
    const scrimW = copyRight + 70;
    scrim.style.width = scrimW + "px";
    scrim.style.opacity = copyVisible ? "0.5" : "0";

    // assembly (pure vertical stacking)
    bottomBun.style.opacity = String(inv(aP, 0.0, 0.1));
    bottomBun.style.transform = `translateY(${lerp(130, 0, easeOutCubic(inv(aP, 0.0, 0.18)))}px)`;
    chicken.style.opacity = String(inv(aP, 0.2, 0.3));
    chicken.style.transform = `translateY(${lerp(-700, 0, easeOutCubic(inv(aP, 0.2, 0.44)))}px)`;
    chickenShadow.style.opacity = String(inv(aP, 0.36, 0.46));
    pickles.style.opacity = String(inv(aP, 0.46, 0.56));
    pickles.style.transform = `translateY(${lerp(-700, 0, easeOutCubic(inv(aP, 0.46, 0.66)))}px)`;
    picklesShadow.style.opacity = String(inv(aP, 0.6, 0.7));
    const topY = lerp(-760, 0, easeOutCubic(inv(aP, 0.7, 0.92)));
    const topOp = String(inv(aP, 0.7, 0.8));
    topBunLower.style.opacity = topOp; topBunUpper.style.opacity = topOp;
    topBunLower.style.transform = `translateY(${topY}px)`;
    topBunUpper.style.transform = `translateY(${topY}px)`;
    const done = inv(aP, 0.92, 1);

    const thresholds = [0.09, 0.30, 0.58, 0.84];
    recipe.forEach((li, i) => li.classList.toggle("on", aP >= thresholds[i]));
    prail.style.height = (aP * 100).toFixed(1) + "%";

    // rail geometry
    const off = (i: number) => (i - pos) * vw;
    const scl = (i: number) => lerp(0.86, 1, clamp(1 - Math.abs(i - pos), 0, 1));
    const fadeImg = (i: number) => clamp(1.25 - Math.abs(i - pos) * 1.40, 0, 1);
    const fadeName = (i: number) => clamp(1.15 - Math.abs(i - pos) * 1.75, 0, 1);
    const fadeCopy = (i: number) => clamp(1.20 - Math.abs(i - pos) * 1.55, 0, 1);

    const ox0 = railOn ? off(0) : 0;
    sandwichEl.style.transform = `translateX(${ox0 + restShift}px) scale(${(lerp(1, 1.03, easeOutCubic(done)) * (railOn ? scl(0) : 1)).toFixed(3)})`;
    sandwichEl.style.opacity = String(railOn ? fadeImg(0) : 1);
    // Sequential handoff from the "Building the Beaut" checklist to the Beaut copy
    // card. It straddles the assembly->rail boundary (P=0.50), during which the Beaut
    // stays parked dead-center (pos=0 until P~0.56). The checklist fades + lifts away
    // FIRST; after a clean beat the copy card rises in — so the two never overlap and
    // there's always exactly one readable thing in the left column.
    const hand = inv(P, 0.46, 0.57);
    const recipeFade = inv(hand, 0, 0.42);   // checklist fully gone by hand .42
    const copyShow = inv(hand, 0.55, 1);     // copy starts only after the beat
    const recipeLift = lerp(0, -12, easeOutCubic(recipeFade));
    const copyRise = lerp(14, 0, easeOutCubic(copyShow));
    recipeEl.style.transform = `translate(${ox0}px,calc(-50% + ${recipeLift}px))`;
    recipeEl.style.opacity = String(1 - recipeFade);
    beautCopy.style.transform = `translate(${ox0}px,calc(-50% + ${copyRise}px))`;
    beautCopy.style.opacity = String(Math.min(copyShow, railOn ? fadeCopy(0) : 1));
    prailBox.style.opacity = String(1 - recipeFade);
    bgword.style.transform = `translate(calc(-50% + ${ox0 * PARALLAX + restShift}px),-50%)`;
    bgword.style.opacity = String((railOn ? fadeName(0) : 1) * 0.24);

    for (let k = 0; k < 2; k++) {
      const i = k + 1;
      railNames[k].style.transform = `translate(calc(-50% + ${off(i) * PARALLAX + restShift}px),-50%)`;
      railNames[k].style.opacity = String((railOn ? fadeName(i) : 0) * 0.55);
      railImgs[k].style.transform = `translate(calc(-50% + ${off(i) + restShift}px),-50%) scale(${scl(i).toFixed(3)})`;
      railImgs[k].style.opacity = String(railOn ? fadeImg(i) : 0);
      railCopy[k].style.transform = `translate(${off(i)}px,-50%)`;
      railCopy[k].style.opacity = String(railOn ? fadeCopy(i) : 0);
    }

    // floral wipe
    let curtainOn = false;
    if (railOn) {
      for (const [a, b, img] of CURTAINS) {
        if (railP >= a && railP <= b) {
          curtainOn = true;
          const tFrac = easeIO((railP - a) / (b - a));
          const Wb = 1.65 * vw;
          const offX = lerp((vw + Wb) / 2, -(vw + Wb) / 2, tFrac);
          curtain.style.transform = `translateX(calc(-50% + ${offX.toFixed(1)}px))`;
          const want = `url("${img}")`;
          if (curtain.style.backgroundImage !== want) curtain.style.backgroundImage = want;
          break;
        }
      }
    }
    curtain.style.opacity = String(curtainOn ? CURTAIN_MAX : 0);

    // background panel + nav theme
    let panelRGB: number[];
    if (!railOn) {
      const st = stages.find((s) => aP < s.to) || stages[stages.length - 1];
      stage.style.backgroundColor = st.bg;
      if (bgword.textContent !== st.word) bgword.textContent = st.word;
      panelRGB = [250, 244, 234];
    } else {
      const seg = clamp(Math.floor(pos), 0, PANELS.length - 2), t = clamp(pos - seg, 0, 1);
      panelRGB = [0, 1, 2].map((j) => Math.round(lerp(PANELS[seg][j], PANELS[seg + 1][j], t)));
      stage.style.backgroundColor = `rgb(${panelRGB[0]},${panelRGB[1]},${panelRGB[2]})`;
    }
    // tint the left scrim to the current panel so the big word fades into it cleanly
    if (copyVisible) {
      const [sr, sg, sb] = panelRGB;
      const solid = ((copyRight / scrimW) * 100).toFixed(1);
      scrim.style.background = `linear-gradient(to right, rgb(${sr},${sg},${sb}) 0%, rgb(${sr},${sg},${sb}) ${solid}%, rgba(${sr},${sg},${sb},0) 100%)`;
    }

    // expose THIS section's nav theme by its current panel luminance; the global
    // nav controller (in Nav.astro) flips the navbar when this section is under it.
    const lum = (0.299 * panelRGB[0] + 0.587 * panelRGB[1] + 0.114 * panelRGB[2]) / 255;
    const navTheme = lum < 0.56 ? "light" : "dark";
    if (build.getAttribute("data-nav-theme") !== navTheme) {
      build.setAttribute("data-nav-theme", navTheme);
      (window as any).__navUpdate?.();
    }
  }

  function onScroll() {
    const total = build.offsetHeight - window.innerHeight;
    render(clamp(-build.getBoundingClientRect().top / total, 0, 1));
  }

  let ticking = false;
  window.addEventListener("scroll", () => {
    if (!ticking) { requestAnimationFrame(() => { onScroll(); ticking = false; }); ticking = true; }
  }, { passive: true });
  window.addEventListener("resize", onScroll);
  onScroll();
</script>
