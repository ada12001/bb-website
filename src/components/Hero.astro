---
// Ma'ono-style landing hero: full-bleed food photo + centered kicker/headline/CTAs
// + a repeating tagline stripe. Standalone — sits above the Build-a-Beaut scroll.
const stripe = ["CRISPY", "JUICY", "BOSSY", "HAND-BREADED", "SINCE 1906"];
// Two IDENTICAL halves so the -50% scroll loops seamlessly (3x each = wide enough
// to fill the viewport). The earlier 3x + -50% misaligned and jumped every loop.
const stripeHalf = [...stripe, ...stripe, ...stripe];
const stripeLoop = [...stripeHalf, ...stripeHalf];
---
<section class="hero" id="hero" data-nav-theme="light">
  <div class="hero-scrim"></div>

  <div class="hero-inner">
    <p class="hero-kicker">Crispy <span>✦</span> Juicy <span>✦</span> Bossy</p>
    <h1 class="hero-title">The Bossier<br />the Better</h1>
    <p class="hero-sub">Hand-breaded, no-nonsense fried chicken. <br />Charlotte, NC — since 1906.</p>
    <div class="hero-cta">
      <a href="/order" class="btn" data-order>Order Now</a>
      <a href="/menu" class="btn-ghost">See the Menu</a>
    </div>
  </div>

  <a href="#build" class="hero-scroll">
    <span>Scroll to build the Beaut</span>
    <span class="line"></span>
  </a>

  <div class="hero-stripe" aria-hidden="true">
    <div class="stripe-track">
      {stripeLoop.map((w) => (<><span>{w}</span><span class="sep">✦</span></>))}
    </div>
  </div>
</section>

<style>
  .hero{
    position:relative;min-height:100svh;
    background:#1a120c url("/img/hero-beaut.jpg") center 60%/cover no-repeat;
    display:flex;flex-direction:column;align-items:center;
    color:var(--cream);text-align:center;overflow:hidden;
  }
  .hero-scrim{
    position:absolute;inset:0;
    background:
      linear-gradient(to bottom, rgba(18,11,7,.6) 0%, rgba(18,11,7,.18) 34%, rgba(18,11,7,.05) 55%, rgba(18,11,7,.5) 100%);
  }
  .hero-inner{position:relative;z-index:2;padding:calc(var(--nav-h) + 7vh) 20px 0;max-width:820px}
  .hero-kicker{
    font-family:var(--font-body);font-weight:700;text-transform:uppercase;
    letter-spacing:.34em;font-size:13px;color:var(--cream);
    display:flex;gap:.7em;justify-content:center;align-items:center;margin-bottom:14px;
    text-shadow:0 1px 10px rgba(0,0,0,.4);
  }
  .hero-kicker span{color:var(--coral)}
  .hero-title{
    font-family:var(--font-display);font-size:clamp(54px,11vw,150px);line-height:.82;
    letter-spacing:.01em;color:#fff;text-shadow:0 6px 30px rgba(0,0,0,.45);
  }
  .hero-sub{
    margin-top:18px;font-size:clamp(15px,1.4vw,18px);font-weight:500;line-height:1.5;
    color:#f3e7d8;text-shadow:0 2px 12px rgba(0,0,0,.5);
  }
  .hero-cta{margin-top:28px;display:flex;gap:14px;justify-content:center;flex-wrap:wrap}

  .hero-scroll{
    position:absolute;bottom:64px;left:50%;transform:translateX(-50%);z-index:2;
    display:flex;flex-direction:column;align-items:center;gap:9px;
    font-size:11px;letter-spacing:.22em;text-transform:uppercase;font-weight:700;color:var(--cream);
    text-shadow:0 1px 10px rgba(0,0,0,.5);
  }
  .hero-scroll .line{width:1px;height:34px;background:var(--cream);transform-origin:top;animation:dripline 1.8s infinite}

  .hero-stripe{
    position:absolute;bottom:0;left:0;right:0;z-index:2;
    background:var(--coral);overflow:hidden;white-space:nowrap;padding:9px 0;
    border-top:2px solid rgba(255,255,255,.25);
  }
  .stripe-track{display:inline-block;animation:scrollx 26s linear infinite;font-family:var(--font-display);font-size:18px;letter-spacing:.05em;color:#fff}
  .stripe-track span{margin:0 16px}
  .stripe-track .sep{color:var(--navy);margin:0 6px}

  @media(prefers-reduced-motion: reduce){
    .hero-scroll .line{animation:none}
    .stripe-track{animation:none}
  }
  @media(max-width:560px){ .hero-sub br{display:none} }
</style>
