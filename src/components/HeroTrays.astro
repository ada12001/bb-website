---
// V2 hero with PARALLAX. Layered depth planes:
//   far wall (slowest) -> counter + rotating trays (foreground) -> copy (fastest + fade)
// Pointer parallax makes it feel 3D at rest; scroll parallax gives a depthful exit.
// Trays still slide in/out on the right; each tray brings its own product name.
const trays = [
  { img: "/img/trays/beaut.png",   name: "The Beaut", tag: "Combo · 14.98",    alt: "The Beaut combo tray", nx: "60%", ny: "52%" },
  { img: "/img/trays/tenders.png", name: "Tenders",   tag: "3pc Combo · 15.98", alt: "Tenders combo tray",  nx: "61%", ny: "49%" },
  { img: "/img/trays/wings.png",   name: "Wings",     tag: "5pc Combo · 15.98", alt: "Wings combo tray",    nx: "61%", ny: "49%" },
];
---
<section class="hero2" id="hero">
  <!-- far plane: back wall + stools + generated floor -->
  <div class="hp-far" id="hpFar"><img src="/img/trays/bg-far.jpg" alt="" /></div>

  <div class="hero2-scrim"></div>

  <!-- foreground plane: counter + rotating trays (move together so food stays on the counter) -->
  <div class="hp-fg" id="hpFg">
    <img class="hp-counter" src="/img/trays/bg-near.png" alt="" />
    <div class="trays" id="trays">
      {trays.map((t, i) => (
        <div class="tray-slide" data-i={i}>
          <img class="tray-img" src={t.img} alt={t.alt} />
          <div class="tray-name" style={`--nx:${t.nx};--ny:${t.ny}`}>
            <span class="tn-script">{t.name}</span>
            <span class="tn-tag">{t.tag}</span>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- copy plane -->
  <div class="hero2-copy hp-copy" id="hpCopy">
    <p class="hero-kicker">Crispy <span>✦</span> Juicy <span>✦</span> Bossy</p>
    <h1 class="hero2-title">The Bossier<br />the Better</h1>
    <p class="hero2-sub">Hand-breaded, no-nonsense fried chicken. <br />Charlotte, NC — since 1906.</p>
    <div class="hero-cta">
      <a href="/order" class="btn">Order Now</a>
      <a href="/menu" class="btn-ghost">See the Menu</a>
    </div>
  </div>

  <a href="#build" class="hero-scroll hero2-scroll" id="hpScroll">
    <span>Scroll to build the Beaut</span>
    <span class="line"></span>
  </a>
</section>

<style>
  .hero2{position:relative;min-height:100svh;overflow:hidden;color:var(--cream);background:#14100b}

  /* far plane — slightly overscanned so parallax never reveals an edge */
  .hp-far{position:absolute;inset:-4.5%;z-index:1;will-change:transform}
  .hp-far img{width:100%;height:100%;object-fit:cover;object-position:center 62%}

  .hero2-scrim{
    position:absolute;inset:0;z-index:2;pointer-events:none;
    background:
      linear-gradient(to right, rgba(15,10,6,.78) 0%, rgba(15,10,6,.5) 32%, rgba(15,10,6,.08) 56%, rgba(15,10,6,0) 72%),
      linear-gradient(to bottom, rgba(15,10,6,.45) 0%, rgba(15,10,6,0) 30%);
  }

  /* foreground plane — counter + trays */
  .hp-fg{position:absolute;inset:0;z-index:3;will-change:transform}
  .hp-counter{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 64%;z-index:1}

  .trays{position:absolute;inset:0;z-index:2}
  .tray-slide{position:absolute;inset:0;will-change:transform;transform:translateX(112%)}
  .tray-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 64%}
  .tray-name{
    position:absolute;left:var(--nx,58%);top:var(--ny,21%);transform:translateX(-50%);text-align:center;white-space:nowrap;
    text-shadow:0 3px 18px rgba(0,0,0,.5);
  }
  .tn-script{display:block;font-family:var(--font-script);color:#fff;font-size:clamp(34px,5vw,68px);line-height:1}
  .tn-tag{display:inline-block;margin-top:10px;font-family:var(--font-body);font-weight:700;text-transform:uppercase;letter-spacing:.12em;font-size:11px;color:#fff;background:var(--coral);padding:5px 13px;border-radius:var(--radius-pill);box-shadow:0 5px 14px rgba(240,83,72,.45);text-shadow:none}

  /* copy plane (parallax via CSS vars so the base centering stays in CSS) */
  .hp-copy{
    position:absolute;z-index:5;left:max(40px,6vw);top:50%;max-width:min(46vw,560px);
    transform:translate(var(--cpx,0px), calc(-50% + var(--cpy,0px)));will-change:transform,opacity;
  }
  .hp-copy .hero-kicker{
    font-family:var(--font-body);font-weight:700;text-transform:uppercase;letter-spacing:.3em;font-size:13px;
    color:var(--cream);display:flex;gap:.6em;align-items:center;margin-bottom:14px;text-shadow:0 1px 10px rgba(0,0,0,.5);
  }
  .hp-copy .hero-kicker span{color:var(--coral)}
  .hero2-title{font-family:var(--font-display);font-size:clamp(48px,7vw,116px);line-height:.82;color:#fff;text-shadow:0 6px 30px rgba(0,0,0,.5)}
  .hero2-sub{margin-top:16px;font-size:clamp(15px,1.3vw,18px);font-weight:500;line-height:1.5;color:#f3e7d8;text-shadow:0 2px 12px rgba(0,0,0,.55)}
  .hero-cta{margin-top:26px;display:flex;gap:14px;flex-wrap:wrap}

  .hero2-scroll{position:absolute;bottom:54px;left:max(40px,6vw);transform:none;align-items:flex-start;z-index:5}

  @media(max-width:820px){
    .hp-far{inset:0}
    .hp-far img{object-position:center 70%}
    .hp-counter,.tray-img{object-position:center 70%}
    .hero2-scrim{background:linear-gradient(to bottom, rgba(15,10,6,.55) 0%, rgba(15,10,6,.15) 30%, rgba(15,10,6,.1) 55%, rgba(15,10,6,.6) 100%)}
    .hp-copy{left:0;right:0;top:14vh;max-width:none;text-align:center;padding:0 20px;transform:none}
    .hp-copy .hero-kicker{justify-content:center}
    .hero-cta{justify-content:center}
    .tray-name{left:50%;top:auto;bottom:16%}
    .hero2-scroll{left:50%;transform:translateX(-50%);align-items:center}
  }
</style>

<script>
  const clamp = (v: number, a: number, b: number) => Math.max(a, Math.min(b, v));

  // ---------- tray rotation (enters & exits on the right, sequential) ----------
  const slides = [...document.querySelectorAll<HTMLElement>("#trays .tray-slide")];
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (slides.length) {
    const DUR = 700;
    const EASE = `transform ${DUR}ms cubic-bezier(.5,0,.2,1)`;
    const DWELL = 4800;
    const OFF = "translateX(112%)";
    let cur = 0;
    slides.forEach((s) => { s.style.transform = OFF; });

    function cycle() {
      const out = slides[cur];
      const next = (cur + 1) % slides.length;
      out.style.transition = EASE;
      out.style.transform = OFF;
      window.setTimeout(() => {
        const inc = slides[next];
        inc.style.transition = "none";
        inc.style.transform = OFF;
        void inc.offsetWidth;
        inc.style.transition = EASE;
        inc.style.transform = "translateX(0)";
        cur = next;
      }, DUR + 80);
    }

    if (reduce) {
      slides[0].style.transform = "translateX(0)";
    } else {
      requestAnimationFrame(() => { slides[0].style.transition = EASE; slides[0].style.transform = "translateX(0)"; });
      let timer = window.setInterval(cycle, DWELL);
      document.addEventListener("visibilitychange", () => {
        window.clearInterval(timer);
        if (!document.hidden) timer = window.setInterval(cycle, DWELL);
      });
    }
  }

  // ---------- parallax (pointer + scroll), playful intensity ----------
  const hero = document.getElementById("hero")!;
  const far = document.getElementById("hpFar")!;
  const fg = document.getElementById("hpFg")!;
  const copy = document.getElementById("hpCopy")!;
  const cue = document.getElementById("hpScroll");

  const desktop = window.matchMedia("(min-width:821px)").matches;

  if (!reduce && desktop) {
    let sp = 0, ticking = false;

    const apply = () => {
      far.style.transform = `translate3d(0, ${(sp * 18).toFixed(1)}px, 0)`;   // back wall recedes (slowest)
      fg.style.transform = `translate3d(0, ${(-sp * 78).toFixed(1)}px, 0)`;   // counter + food lift (playful)
      copy.style.setProperty("--cpy", `${(-sp * 122).toFixed(1)}px`);          // copy drifts up...
      copy.style.opacity = String(clamp(1 - sp * 1.25, 0, 1));                 // ...and fades
      if (cue) cue.style.opacity = String(clamp(1 - sp * 2.2, 0, 1));
      ticking = false;
    };
    const onScroll = () => {
      sp = clamp(window.scrollY / (hero.offsetHeight * 0.9), 0, 1);
      if (!ticking) { ticking = true; requestAnimationFrame(apply); }
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }
</script>
