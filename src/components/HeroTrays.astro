---
// V2 hero: static shack-counter background; a tray of food slides out-left while
// the next slides in from the right, cycling Beaut -> Tenders -> Wings. Fixed brand
// copy on the left; each tray brings in its own product name. Standalone (above the scroll).
const trays = [
  { img: "/img/trays/beaut.png",   name: "The Beaut",  tag: "Combo · 14.98", alt: "The Beaut combo tray" },
  { img: "/img/trays/tenders.png", name: "Tenders",    tag: "3pc Combo · 15.98", alt: "Tenders combo tray" },
  { img: "/img/trays/wings.png",   name: "Wings",      tag: "5pc Combo · 15.98", alt: "Wings combo tray" },
];
---
<section class="hero2" id="hero">
  <div class="hero2-scrim"></div>

  <!-- rotating trays + their names -->
  <div class="trays" id="trays">
    {trays.map((t, i) => (
      <div class="tray-slide" data-i={i}>
        <img class="tray-img" src={t.img} alt={t.alt} />
        <div class="tray-name">
          <span class="tn-script">{t.name}</span>
          <span class="tn-tag">{t.tag}</span>
        </div>
      </div>
    ))}
  </div>

  <!-- fixed brand copy -->
  <div class="hero2-copy">
    <p class="hero-kicker">Crispy <span>✦</span> Juicy <span>✦</span> Bossy</p>
    <h1 class="hero2-title">The Bossier<br />the Better</h1>
    <p class="hero2-sub">Hand-breaded, no-nonsense fried chicken.<br />Charlotte, NC — since 1906.</p>
    <div class="hero-cta">
      <a href="/order" class="btn">Order Now</a>
      <a href="/menu" class="btn-ghost">See the Menu</a>
    </div>
  </div>

  <a href="#build" class="hero-scroll hero2-scroll">
    <span>Scroll to build the Beaut</span>
    <span class="line"></span>
  </a>
</section>

<style>
  .hero2{
    position:relative;min-height:100svh;overflow:hidden;color:var(--cream);
    background:#14100b url("/img/trays/bg.jpg") center 64%/cover no-repeat;
  }
  /* darken the left so the fixed copy reads over the scene */
  .hero2-scrim{
    position:absolute;inset:0;z-index:1;
    background:
      linear-gradient(to right, rgba(15,10,6,.78) 0%, rgba(15,10,6,.5) 32%, rgba(15,10,6,.08) 56%, rgba(15,10,6,0) 72%),
      linear-gradient(to bottom, rgba(15,10,6,.45) 0%, rgba(15,10,6,0) 30%);
  }

  /* rotating trays */
  .trays{position:absolute;inset:0;z-index:2}
  .tray-slide{position:absolute;inset:0;will-change:transform;transform:translateX(110%)}
  .tray-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 64%}
  .tray-name{
    position:absolute;left:58%;top:21%;transform:translateX(-50%);text-align:center;white-space:nowrap;
    text-shadow:0 3px 18px rgba(0,0,0,.5);
  }
  .tn-script{display:block;font-family:var(--font-script);color:#fff;font-size:clamp(34px,5vw,68px);line-height:1}
  .tn-tag{display:inline-block;margin-top:8px;font-family:var(--font-body);font-weight:700;text-transform:uppercase;letter-spacing:.16em;font-size:12px;color:var(--mint)}

  /* fixed brand copy (above the trays so they slide behind it) */
  .hero2-copy{
    position:absolute;z-index:5;left:max(40px,6vw);top:50%;transform:translateY(-50%);
    max-width:min(46vw,560px);
  }
  .hero2-copy .hero-kicker{
    font-family:var(--font-body);font-weight:700;text-transform:uppercase;letter-spacing:.3em;font-size:13px;
    color:var(--cream);display:flex;gap:.6em;align-items:center;margin-bottom:14px;text-shadow:0 1px 10px rgba(0,0,0,.5);
  }
  .hero2-copy .hero-kicker span{color:var(--coral)}
  .hero2-title{font-family:var(--font-display);font-size:clamp(48px,7vw,116px);line-height:.82;color:#fff;text-shadow:0 6px 30px rgba(0,0,0,.5)}
  .hero2-sub{margin-top:16px;font-size:clamp(15px,1.3vw,18px);font-weight:500;line-height:1.5;color:#f3e7d8;text-shadow:0 2px 12px rgba(0,0,0,.55)}
  .hero-cta{margin-top:26px;display:flex;gap:14px;flex-wrap:wrap}

  .hero2-scroll{position:absolute;bottom:54px;left:max(40px,6vw);transform:none;align-items:flex-start;z-index:5}

  @media(max-width:820px){
    .hero2{background-position:center 70%}
    .hero2-scrim{background:linear-gradient(to bottom, rgba(15,10,6,.55) 0%, rgba(15,10,6,.15) 30%, rgba(15,10,6,.1) 55%, rgba(15,10,6,.6) 100%)}
    .hero2-copy{left:0;right:0;top:14vh;transform:none;max-width:none;text-align:center;padding:0 20px}
    .hero2-copy .hero-kicker{justify-content:center}
    .hero-cta{justify-content:center}
    .tray-name{left:50%;top:auto;bottom:16%}
    .hero2-scroll{left:50%;transform:translateX(-50%);align-items:center}
  }
</style>

<script>
  const slides = [...document.querySelectorAll<HTMLElement>("#trays .tray-slide")];
  if (slides.length) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const EASE = "transform .9s cubic-bezier(.6,0,.2,1)";
    let cur = 0;
    slides.forEach((s, i) => { s.style.transform = i === 0 ? "translateX(0)" : "translateX(110%)"; });

    function show(next: number) {
      const out = slides[cur], inc = slides[next];
      inc.style.transition = "none";
      inc.style.transform = "translateX(110%)";
      void inc.offsetWidth;                 // reflow so the reset isn't animated
      inc.style.transition = EASE; inc.style.transform = "translateX(0)";
      out.style.transition = EASE; out.style.transform = "translateX(-110%)";
      cur = next;
    }

    if (!reduce) {
      let timer = window.setInterval(() => show((cur + 1) % slides.length), 4200);
      document.addEventListener("visibilitychange", () => {
        clearInterval(timer);
        if (!document.hidden) timer = window.setInterval(() => show((cur + 1) % slides.length), 4200);
      });
    }
  }
</script>
