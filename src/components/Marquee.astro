---
// The track is two identical halves and scrolls -50% to loop seamlessly.
// Each half repeats the phrase set 3x so a single half is always wider than the
// viewport (even on ultrawide) — otherwise the loop shows a gap on wide screens.
interface Props { items?: string[]; }
const { items = [
  "THE BOSSIER THE BETTER",
  "RESPECT THE PICKLES",
  "SINCE 1906",
  "NO SUCH THING AS TOO MANY PICKLES",
] } = Astro.props;
const half = [...items, ...items, ...items];
const loop = [...half, ...half];
---
<div class="marquee" aria-hidden="true" data-nav-theme="light">
  <div class="track">
    {loop.map((t, i) => (
      <>
        <span class={i % 2 === 0 ? "c" : ""}>{t}</span><span>&#10022;</span>
      </>
    ))}
  </div>
</div>
