---
// `hl` = the destination page's signature colour; the hover "sticker" uses it.
const links = [
  { href: "/menu", label: "Menu", hl: "#f4d9c5" },        // peach
  { href: "/catering", label: "Catering", hl: "#e5d72a" }, // yellow
  { href: "/rewards", label: "Rewards", hl: "#f05348" },   // coral
  { href: "/story", label: "Our Story", hl: "#a0d8d1" },   // mint
  { href: "/locations", label: "Locations", hl: "#b6b9db" }, // periwinkle
  { href: "/careers", label: "Careers", hl: "#f39887" },   // salmon
];
---
<nav class="nav">
  <a href="/" class="nav-logo" aria-label="Bossy Beulah's home">
    <img class="logo logo--coral" src="/img/logo-coral.png" alt="Bossy Beulah's Chicken Shack" />
    <img class="logo logo--white" src="/img/logo-white.png" alt="" aria-hidden="true" />
  </a>
  <div class="nav-right">
    <div class="nav-links" id="navMenu">
      {links.map((l) => <a href={l.href} style={`--hl:${l.hl}`} data-hl={l.hl}>{l.label}</a>)}
    </div>
    <a href="/order" class="order-btn" data-order>Order Now</a>
    <button class="nav-toggle" id="navToggle" type="button" aria-label="Toggle menu" aria-expanded="false" aria-controls="navMenu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<script>
  // Global nav-theme controller. Each section can declare data-nav-theme="light|dark";
  // whichever one is under the navbar decides the nav colors. Default = dark.
  const nav = document.querySelector(".nav") as HTMLElement | null;
  if (nav) {
    const navLinks = Array.from(document.querySelectorAll<HTMLElement>("#navMenu a"));

    const parseRGB = (s: string): number[] | null => {
      const m = s.match(/rgba?\(([^)]+)\)/);
      if (!m) return null;
      const p = m[1].split(",").map((x) => parseFloat(x));
      if (p[3] !== undefined && p[3] < 0.1) return null; // transparent
      return [p[0], p[1], p[2]];
    };
    const hexRGB = (h: string): number[] => {
      const n = parseInt(h.slice(1), 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    };
    const lum = (c: number[]) => (0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2]) / 255;
    const dist = (a: number[], b: number[]) => Math.hypot(a[0] - b[0], a[1] - b[1], a[2] - b[2]);

    // the actual visible background colour directly under the navbar's centre
    const sampleBg = (): number[] => {
      const r = nav.getBoundingClientRect();
      const prev = nav.style.pointerEvents;
      nav.style.pointerEvents = "none";
      let el = document.elementFromPoint(
        Math.round(window.innerWidth / 2),
        Math.round(r.top + r.height / 2),
      ) as HTMLElement | null;
      nav.style.pointerEvents = prev;
      while (el && el !== document.documentElement) {
        const c = parseRGB(getComputedStyle(el).backgroundColor);
        if (c) return c;
        el = el.parentElement;
      }
      return [250, 244, 234]; // cream
    };

    const update = () => {
      const r = nav.getBoundingClientRect();
      const line = r.top + r.height / 2; // sample at the navbar's vertical middle
      let theme = "dark";
      for (const s of document.querySelectorAll<HTMLElement>("[data-nav-theme]")) {
        const b = s.getBoundingClientRect();
        if (b.top <= line && b.bottom > line) { theme = s.getAttribute("data-nav-theme") || "dark"; break; }
      }

      const bg = sampleBg();
      nav.style.setProperty("--nav-bg", `rgb(${bg[0]},${bg[1]},${bg[2]})`); // opaque mobile bar
      const L = lum(bg);
      // White logo/links are needed over anything the authored theme marks "light",
      // OR over a background that's actually dark or warm-saturated (coral/salmon) —
      // e.g. the coral category bars on the catering menu, which the theme doesn't tag.
      const warm = bg[0] > 200 && bg[0] - bg[2] > 60 && bg[0] - bg[1] > 40;
      document.body.classList.toggle("nav-light", theme === "light" || L < 0.56 || warm);
      document.body.classList.toggle("nav-bg-dark", L < 0.32);
      // Only fall back to a navy sticker when the sticker colour is essentially the
      // SAME as the background it sits on (e.g. Rewards' coral over the coral header,
      // Locations' periwinkle over the periwinkle header). Distinct-but-related hues
      // (periwinkle vs mint ~39 apart) keep their own colour.
      for (const a of navLinks) {
        const hl = a.dataset.hl;
        const blends = !!hl && dist(hexRGB(hl), bg) < 30;
        a.classList.toggle("hl-fallback", blends);
      }
    };
    (window as any).__navUpdate = update; // let dynamic sections (the build) force a re-check
    let ticking = false;
    const onScroll = () => {
      if (!ticking) { ticking = true; requestAnimationFrame(() => { update(); ticking = false; }); }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", update);
    update();
    // re-check shortly after load in case fonts/images shift section heights
    window.addEventListener("load", () => setTimeout(update, 50));
  }

  // Mobile menu (hamburger) toggle
  const toggle = document.getElementById("navToggle");
  const menu = document.getElementById("navMenu");
  if (toggle && menu) {
    const setOpen = (open: boolean) => {
      toggle.setAttribute("aria-expanded", String(open));
      menu.classList.toggle("open", open);
    };
    toggle.addEventListener("click", () => setOpen(toggle.getAttribute("aria-expanded") !== "true"));
    menu.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => setOpen(false)));
    window.addEventListener("resize", () => { if (window.innerWidth > 900) setOpen(false); });
    document.addEventListener("keydown", (e) => { if (e.key === "Escape") setOpen(false); });
  }
</script>
