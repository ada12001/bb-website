---
import { getCollection } from "astro:content";
import { APP_IOS, APP_ANDROID, DELIVERY_DOORDASH, DELIVERY_UBEREATS } from "../consts";

const locations = await getCollection("locations");

// Deep-links to a specific combo on Toast. Toast item GUIDs are SHARED across all
// locations, so we just append the item path to a location's base order URL —
// works for every location automatically (and any future ones).
// `unavailable` = location ids that don't carry the item (fall back to the menu).
const ITEMS: Record<string, { name: string; path: string; unavailable?: string[] }> = {
  "cheesy-beaut": {
    name: "The Cheesy Beaut Combo",
    path: "item-the-cheesy-beaut-combo_7330305b-9cbb-4793-92a2-adf4d847789f",
    unavailable: ["park-road"], // not listed at Park Road (pending confirmation)
  },
  "hot-thigh": {
    name: "Hot Thigh Combo",
    path: "item-the-hot-thigh-combo_dd4b4cfe-a88b-41b9-83d2-df0e66f389e4",
  },
};
---
<div class="om-overlay" id="orderModal" hidden>
  <div class="om-backdrop" data-om-close></div>
  <div class="om-dialog" role="dialog" aria-modal="true" aria-labelledby="omTitle">
    <button class="om-close" data-om-close aria-label="Close">&times;</button>
    <p class="om-kicker">Respect the pickles</p>
    <h2 class="om-title" id="omTitle">Order Up</h2>
    <p class="om-sub">Pick your shack, then choose how you'd like to order.</p>
    <p class="om-item" id="omItemNote" hidden></p>

    <span class="om-field" id="omFieldLabel">Location</span>
    <div class="om-dd" id="omDD">
      <button type="button" class="om-dd-trigger" id="omTrigger" aria-haspopup="listbox" aria-expanded="false" aria-labelledby="omFieldLabel omLabel">
        <span class="om-dd-label" id="omLabel">Choose your shack…</span>
        <span class="om-dd-chev" aria-hidden="true"></span>
      </button>
      <ul class="om-dd-list" id="omList" role="listbox" aria-label="Pick a location" hidden>
        {locations.map((l) => (
          <li class="om-dd-opt" role="option" aria-selected="false" data-url={l.data.orderUrl} data-id={l.id} data-name={l.data.name}>
            <span class="opt-name">{l.data.name}</span>
            <span class="opt-city">{l.data.city}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="om-actions">
      <button class="om-btn om-online om-wide" id="omOnline" disabled>
        Online<small>order for pickup</small>
      </button>
      <button class="om-btn om-delivery" id="omDelivery">
        Delivery<small>DoorDash · Uber Eats</small>
      </button>
      <button class="om-btn om-app" id="omApp" data-ios={APP_IOS} data-android={APP_ANDROID}>
        The App<small>iOS &amp; Android</small>
      </button>
    </div>

    <div class="om-reveal" id="omStores" hidden>
      <span>Get the Bossy app:</span>
      <a href={APP_IOS} target="_blank" rel="noopener">App Store</a>
      <a href={APP_ANDROID} target="_blank" rel="noopener">Google Play</a>
    </div>
    <div class="om-reveal" id="omDelivery2" hidden>
      <span>Get it delivered:</span>
      <a href={DELIVERY_DOORDASH} target="_blank" rel="noopener">DoorDash</a>
      <a href={DELIVERY_UBEREATS} target="_blank" rel="noopener">Uber Eats</a>
    </div>

    <script type="application/json" id="omItems" set:html={JSON.stringify(ITEMS)}></script>
  </div>
</div>

<style is:global>
  .om-overlay{position:fixed;inset:0;z-index:1000;display:flex;align-items:center;justify-content:center;padding:20px}
  .om-overlay[hidden]{display:none}
  .om-backdrop{position:absolute;inset:0;background:rgba(20,16,11,.62);backdrop-filter:blur(4px);animation:omFade .2s ease}
  .om-dialog{
    position:relative;z-index:1;width:min(440px,100%);background:var(--cream);
    border-radius:18px;padding:34px 30px 30px;text-align:center;
    box-shadow:0 30px 80px rgba(20,16,11,.45);animation:omPop .26s var(--ease-out);
  }
  @keyframes omFade{from{opacity:0}to{opacity:1}}
  @keyframes omPop{from{opacity:0;transform:translateY(14px) scale(.97)}to{opacity:1;transform:none}}

  .om-close{
    position:absolute;top:12px;right:14px;width:34px;height:34px;border:none;cursor:pointer;
    background:transparent;color:var(--navy);font-size:26px;line-height:1;border-radius:50%;opacity:.6;
  }
  .om-close:hover{opacity:1;background:rgba(0,0,0,.06)}
  .om-kicker{font-family:var(--font-script);color:var(--coral);font-size:24px;transform:rotate(-2deg);margin-bottom:2px}
  .om-title{font-family:var(--font-display);color:var(--navy);font-size:clamp(34px,7vw,48px);line-height:.9}
  .om-sub{color:var(--ink-soft);font-size:14px;font-weight:500;margin:8px 0 14px}
  .om-item{display:inline-block;margin:0 0 18px;font-family:var(--font-body);font-weight:700;text-transform:uppercase;letter-spacing:.08em;font-size:11px;color:#fff;background:var(--coral);padding:6px 14px;border-radius:var(--radius-pill)}
  .om-item[hidden]{display:none}

  .om-field{display:block;text-align:left;font-weight:700;text-transform:uppercase;letter-spacing:.12em;font-size:11px;color:var(--coral);margin-bottom:7px}

  /* ---- branded custom dropdown ---- */
  .om-dd{position:relative;text-align:left}
  .om-dd-trigger{
    width:100%;display:flex;align-items:center;justify-content:space-between;gap:10px;cursor:pointer;
    font-family:var(--font-body);font-size:16px;font-weight:600;color:var(--navy);
    padding:14px 16px;border:2px solid #e2d8c8;border-radius:12px;background:#fff;
    transition:border-color var(--dur-fast) var(--ease-out),box-shadow var(--dur-fast) var(--ease-out);
  }
  .om-dd-trigger:hover{border-color:#d9b5ac}
  .om-dd-trigger[aria-expanded="true"]{border-color:var(--coral);box-shadow:0 0 0 3px rgba(240,83,72,.15)}
  .om-dd-label{color:#9a9183}                 /* placeholder tone */
  .om-dd-label.chosen{color:var(--navy)}
  .om-dd-chev{
    width:9px;height:9px;border-right:2.5px solid var(--coral);border-bottom:2.5px solid var(--coral);
    transform:rotate(45deg) translateY(-2px);flex:0 0 auto;transition:transform var(--dur-fast) var(--ease-out)
  }
  .om-dd-trigger[aria-expanded="true"] .om-dd-chev{transform:rotate(225deg) translateY(-2px)}

  .om-dd-list{
    position:absolute;top:calc(100% + 8px);left:0;right:0;z-index:5;list-style:none;
    background:#fff;border:2px solid var(--coral);border-radius:14px;overflow:hidden;
    box-shadow:0 18px 40px rgba(20,16,11,.22);max-height:280px;overflow-y:auto;
    animation:omDrop .16s var(--ease-out);
  }
  .om-dd-list[hidden]{display:none}
  @keyframes omDrop{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}
  .om-dd-opt{
    display:flex;flex-direction:column;gap:1px;padding:11px 16px;cursor:pointer;
    border-bottom:1px solid #f1e9dc;transition:background var(--dur-fast) ease;
  }
  .om-dd-opt:last-child{border-bottom:none}
  .om-dd-opt .opt-name{font-weight:700;color:var(--navy);font-size:15px}
  .om-dd-opt .opt-city{font-size:12px;color:var(--ink-soft)}
  .om-dd-opt:hover,.om-dd-opt.active{background:var(--peach)}
  .om-dd-opt[aria-selected="true"]{background:var(--coral)}
  .om-dd-opt[aria-selected="true"] .opt-name,
  .om-dd-opt[aria-selected="true"] .opt-city{color:#fff}

  .om-actions{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:18px}
  .om-wide{grid-column:1 / -1}
  .om-btn{
    display:flex;flex-direction:column;align-items:center;gap:3px;cursor:pointer;border:none;
    border-radius:14px;padding:15px 12px;font-family:var(--font-display);font-size:21px;color:#fff;line-height:1;
    transition:transform var(--dur-fast) var(--ease-out),box-shadow var(--dur-fast) var(--ease-out);
  }
  .om-btn small{font-family:var(--font-body);font-weight:600;font-size:10px;text-transform:uppercase;letter-spacing:.1em;opacity:.85}
  .om-btn:hover{transform:translateY(-2px)}
  .om-online{background:var(--coral);box-shadow:0 8px 20px rgba(240,83,72,.4)}
  .om-online:disabled{background:#e7b4af;cursor:not-allowed;box-shadow:none;transform:none}
  .om-delivery{background:var(--mint);color:var(--navy)}
  .om-app{background:var(--navy);box-shadow:0 8px 20px rgba(30,35,73,.4)}

  .om-reveal{margin-top:14px;display:flex;flex-wrap:wrap;gap:12px;align-items:center;justify-content:center;font-size:13px;color:var(--ink-soft)}
  .om-reveal[hidden]{display:none}
  .om-reveal a{font-weight:700;color:var(--navy);text-decoration:underline;text-underline-offset:3px}
  .om-reveal a:hover{color:var(--coral)}

  body.om-open{overflow:hidden}
</style>

<script>
  const overlay = document.getElementById("orderModal");
  if (overlay) {
    const online = document.getElementById("omOnline") as HTMLButtonElement;
    const app = document.getElementById("omApp") as HTMLButtonElement;
    const stores = document.getElementById("omStores") as HTMLElement;
    const deliveryBtn = document.getElementById("omDelivery") as HTMLButtonElement;
    const delivery = document.getElementById("omDelivery2") as HTMLElement;
    const hideReveals = () => { stores.hidden = true; delivery.hidden = true; };
    const trigger = document.getElementById("omTrigger") as HTMLButtonElement;
    const label = document.getElementById("omLabel") as HTMLElement;
    const list = document.getElementById("omList") as HTMLElement;
    const opts = [...list.querySelectorAll<HTMLElement>(".om-dd-opt")];
    const note = document.getElementById("omItemNote") as HTMLElement;
    let ITEMS: Record<string, { name: string; path: string; unavailable?: string[] }> = {};
    try { ITEMS = JSON.parse(document.getElementById("omItems")?.textContent || "{}"); } catch {}
    let lastTrigger: HTMLElement | null = null;
    let selectedUrl = "";
    let selectedId = "";
    let requestedItem: string | null = null;
    let active = -1;

    // ---- branded dropdown ----
    const setActive = (i: number) => {
      active = i;
      opts.forEach((o, k) => o.classList.toggle("active", k === i));
      if (i >= 0) opts[i].scrollIntoView({ block: "nearest" });
    };
    const openList = () => {
      list.hidden = false;
      trigger.setAttribute("aria-expanded", "true");
      setActive(opts.findIndex((o) => o.getAttribute("aria-selected") === "true"));
    };
    const closeList = () => {
      list.hidden = true;
      trigger.setAttribute("aria-expanded", "false");
      active = -1;
    };
    const choose = (opt: HTMLElement) => {
      selectedUrl = opt.dataset.url || "";
      selectedId = opt.dataset.id || "";
      label.textContent = opt.dataset.name || "";
      label.classList.add("chosen");
      opts.forEach((o) => o.setAttribute("aria-selected", o === opt ? "true" : "false"));
      online.disabled = !selectedUrl;
      closeList();
      trigger.focus();
    };

    trigger.addEventListener("click", (e) => { e.stopPropagation(); list.hidden ? openList() : closeList(); });
    opts.forEach((opt, i) => {
      opt.addEventListener("click", () => choose(opt));
      opt.addEventListener("mousemove", () => setActive(i));
    });

    // ---- modal open/close ----
    const open = (t?: HTMLElement) => {
      lastTrigger = t || null;
      // item context (e.g. "Add to order" on a specific combo)
      requestedItem = t?.dataset.order ? t.dataset.order : null; // data-order="cheesy-beaut"
      const meta = requestedItem && ITEMS[requestedItem] ? ITEMS[requestedItem] : null;
      if (meta) { note.textContent = `Adding · ${meta.name}`; note.hidden = false; }
      else { note.hidden = true; }
      overlay.hidden = false;
      document.body.classList.add("om-open");
      trigger.focus();
    };
    const close = () => {
      overlay.hidden = true;
      document.body.classList.remove("om-open");
      closeList();
      hideReveals();
      lastTrigger?.focus?.();
    };

    document.querySelectorAll<HTMLElement>("[data-order]").forEach((el) =>
      el.addEventListener("click", (e) => { e.preventDefault(); open(el); })
    );
    overlay.querySelectorAll("[data-om-close]").forEach((el) => el.addEventListener("click", close));
    // click anywhere inside the modal but outside the dropdown closes the list
    overlay.addEventListener("click", (e) => {
      if (!(e.target as HTMLElement).closest(".om-dd")) closeList();
    });

    // ---- keyboard ----
    trigger.addEventListener("keydown", (e) => {
      if (list.hidden && ["ArrowDown", "ArrowUp", "Enter", " "].includes(e.key)) { e.preventDefault(); openList(); }
    });
    document.addEventListener("keydown", (e) => {
      if (overlay.hidden) return;
      if (!list.hidden) {
        if (e.key === "ArrowDown") { e.preventDefault(); setActive(Math.min(active + 1, opts.length - 1)); }
        else if (e.key === "ArrowUp") { e.preventDefault(); setActive(Math.max(active - 1, 0)); }
        else if (e.key === "Enter") { e.preventDefault(); if (active >= 0) choose(opts[active]); }
        else if (e.key === "Escape") { e.preventDefault(); closeList(); trigger.focus(); }
      } else if (e.key === "Escape") {
        close();
      }
    });

    // ---- actions ----
    online.addEventListener("click", () => {
      if (!selectedUrl) return;
      // build the combo deep-link by appending the shared item path to this
      // location's base order URL (unless the item isn't carried there)
      let target = selectedUrl;
      const meta = requestedItem ? ITEMS[requestedItem] : null;
      if (meta && meta.path && !(meta.unavailable || []).includes(selectedId)) {
        target = selectedUrl.replace(/\/+$/, "") + "/" + meta.path;
      }
      window.open(target, "_blank", "noopener");
    });
    app.addEventListener("click", () => {
      const ua = navigator.userAgent || "";
      const isIOS = /iPad|iPhone|iPod/.test(ua) || (navigator.platform === "MacIntel" && (navigator as any).maxTouchPoints > 1);
      const isAndroid = /Android/.test(ua);
      if (isIOS) window.open(app.dataset.ios, "_blank", "noopener");
      else if (isAndroid) window.open(app.dataset.android, "_blank", "noopener");
      else { stores.hidden = false; delivery.hidden = true; } // desktop: let them pick a store
    });
    deliveryBtn.addEventListener("click", () => { delivery.hidden = false; stores.hidden = true; });

    (window as any).__openOrder = open;
  }
</script>
