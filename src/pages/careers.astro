---
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";
// TODO: replace with real open roles (or pull from an ATS later).
const roles = [
  { title: "Line Cook", location: "Charlotte, NC", type: "Full-time" },
  { title: "Counter / Cashier", location: "Charlotte, NC", type: "Part-time" },
  { title: "Shift Lead", location: "Charlotte, NC", type: "Full-time" },
];
---
<Base title="Careers — Bossy Beulah's" description="Join the Beulah's crew. We're hiring in Charlotte.">
  <PageHeader kicker="join the crew" title="CAREERS" bg="var(--salmon)" />
  <div class="careers">
    <p class="intro">We keep it simple, we keep it bossy, and we take care of our people. If that sounds like you, come work the counter or the fryer.</p>
    <ul class="roles">
      {roles.map((r) => (
        <li>
          <div>
            <h3>{r.title}</h3>
            <p>{r.location} · {r.type}</p>
          </div>
          <a class="btn" href="mailto:jobs@bossybeulahs.com?subject=Application">Apply</a>
        </li>
      ))}
    </ul>
    <p class="note">Placeholder roles — swap for real openings or connect an ATS.</p>
  </div>
</Base>

<style>
  .careers{max-width:760px;margin:0 auto;padding:56px 24px 96px}
  .intro{font-size:18px;line-height:1.6;color:var(--ink);margin-bottom:32px}
  .roles{list-style:none}
  .roles li{display:flex;align-items:center;justify-content:space-between;gap:16px;padding:22px 0;border-top:1px solid #efe7da}
  .roles li:last-child{border-bottom:1px solid #efe7da}
  .roles h3{font-family:var(--font-display);color:var(--navy);font-size:22px}
  .roles li > div p{color:var(--ink-soft);font-size:14px;margin-top:2px}
  .note{margin-top:28px;font-size:12px;color:var(--coral)}
</style>
