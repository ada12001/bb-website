---
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";
---
<Base title="Catering — Bossy Beulah's" description="Feed the whole crew. Bossy Beulah's catering for offices, parties & events.">
  <PageHeader kicker="feed the whole crew" title="CATERING" bg="var(--yellow)" />
  <div class="cater">
    <p>From box lunches to full spreads — let Bossy do the bossing. Tell us about your event and we'll take it from there.</p>
    <form class="inquiry" name="catering" onsubmit="return false">
      <div class="grid">
        <label>Name<input type="text" name="name" required /></label>
        <label>Email<input type="email" name="email" required /></label>
        <label>Phone<input type="tel" name="phone" /></label>
        <label>Event date<input type="date" name="date" /></label>
        <label>Headcount<input type="number" name="headcount" min="1" /></label>
        <label>Location<input type="text" name="location" /></label>
      </div>
      <label>Details<textarea name="details" rows="4"></textarea></label>
      <button class="btn" type="submit">Send inquiry</button>
      <p class="note">Placeholder form — connect to email / form handler (Vercel + Formspree, Resend, etc.).</p>
    </form>
  </div>
</Base>

<style>
  .cater{max-width:680px;margin:0 auto;padding:56px 24px 96px}
  .cater > p{font-size:18px;line-height:1.6;color:var(--ink);margin-bottom:28px}
  .grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
  label{display:flex;flex-direction:column;gap:6px;font-weight:700;font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--navy);margin-bottom:16px}
  input,textarea{font-family:inherit;font-size:15px;font-weight:400;text-transform:none;letter-spacing:normal;padding:11px 13px;border:1px solid #e0d6c7;border-radius:8px;background:#fff}
  .inquiry .btn{margin-top:6px}
  .note{margin-top:18px;font-size:12px;color:var(--coral)}
  @media(max-width:560px){ .grid{grid-template-columns:1fr} }
</style>
