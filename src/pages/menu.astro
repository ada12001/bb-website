---
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";
import { getCollection } from "astro:content";

const items = await getCollection("menu");
const order = ["sandwiches", "chicken", "salads", "sides", "kids", "drinks", "sauces", "desserts"];
const labels: Record<string, string> = {
  sandwiches: "The Sandwiches", chicken: "All-Natural Chicken", salads: "Salads",
  sides: "Sides", kids: "Kids", drinks: "Drinks", sauces: "Sauces · 99¢ each", desserts: "Desserts",
};
const groups = order
  .map((cat) => ({ cat, items: items.filter((i) => i.data.category === cat) }))
  .filter((g) => g.items.length);
const fmt = (n?: number) => (n == null ? "" : n.toFixed(2));
---
<Base title="Menu — Bossy Beulah's" description="The whole no-nonsense lineup: Beauts, wings, bites, tenders, salads, sides, sauces & more.">
  <PageHeader kicker="small menu, mouth-watering impact" title="THE MENU" bg="var(--peach)" />

  <div class="menu">
    {groups.map((g) => (
      <section class="cat">
        <h2>{labels[g.cat]}</h2>
        <ul>
          {g.items.map((i) => (
            <li>
              <div class="row">
                <span class="name">{i.data.name}</span>
                <span class="dots"></span>
                <span class="price">
                  {i.data.variants
                    ? i.data.variants.map((v) => `${v.label} ${fmt(v.price)}`).join(" · ")
                    : fmt(i.data.price)}
                </span>
              </div>
              {i.data.description && <p class="desc">{i.data.description}</p>}
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</Base>

<style>
  .menu{max-width:760px;margin:0 auto;padding:56px 24px 96px}
  .cat{margin-bottom:48px}
  .cat h2{font-family:var(--font-display);color:var(--coral);font-size:clamp(26px,4vw,38px);margin-bottom:18px;letter-spacing:.01em}
  .cat ul{list-style:none}
  .cat li{margin:16px 0}
  .row{display:flex;align-items:baseline;gap:8px}
  .name{font-weight:700;color:var(--navy);font-size:18px}
  .dots{flex:1;border-bottom:2px dotted #d7cdbe;transform:translateY(-4px)}
  .price{font-weight:700;color:var(--navy);font-size:15px;white-space:nowrap}
  .desc{color:var(--ink-soft);font-size:14px;margin-top:3px;max-width:90%}
</style>
