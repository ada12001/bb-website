---
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";
// TODO: wire to the real ordering provider (Toast / Olo / app deep-link).
const providers = [
  { label: "Order Pickup", href: "#" },
  { label: "Order Delivery", href: "#" },
];
---
<Base title="Order — Bossy Beulah's" description="Order The Beaut for pickup or delivery.">
  <PageHeader kicker="the bossier the better" title="ORDER NOW" bg="var(--coral)" />
  <div class="order">
    <p>Pick your poison. Online ordering links out to our ordering partner.</p>
    <div class="opts">
      {providers.map((p) => <a class="btn" href={p.href}>{p.label}</a>)}
    </div>
    <p class="note">Placeholder — connect the real ordering provider / deep links.</p>
  </div>
</Base>

<style>
  .order{max-width:560px;margin:0 auto;padding:56px 24px 96px;text-align:center}
  .order p{font-size:18px;color:var(--ink);margin-bottom:28px}
  .opts{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}
  .note{margin-top:32px;font-size:12px;color:var(--coral)}
</style>
