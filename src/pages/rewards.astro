---
import Base from "../layouts/Base.astro";
import { APP_IOS, APP_ANDROID, REWARDS_URL } from "../consts";

const earn = [
  { item: "Sides", points: 60 },
  { item: "Sandwiches", points: 100 },
  { item: "Bossy Bites", points: 110 },
];
const perks = [
  { h: "Earn on every order", p: "$1 spent = 1 point. Points stack on everything you order." },
  { h: "Exclusive in-app offers", p: "Members-only deals and surprises, straight in the app." },
  { h: "Redeem for free food", p: "Cash your points in for free sides, sammies, and Bossy Bites." },
];
---
<Base
  title="Rewards — Aunt Beaut's Buddies"
  description="Join Aunt Beaut's Buddies. Earn a point for every dollar, unlock exclusive in-app offers, and redeem for free Bossy Beulah's food."
>
  <div class="rw-banner" data-nav-theme="light">Might as well earn somethin'</div>

  <section class="rw-hero" data-nav-theme="light">
    <p class="rw-join">Join</p>
    <h1 class="rw-title">
      <span class="rw-aunt">Aunt Beaut's</span>
      <span class="rw-buddies">Buddies</span>
    </h1>
    <p class="rw-lead">Beulah's loyalty program. Earn points on every order, unlock exclusive in-app offers, and cash them in for free food. Bossy takes care of her regulars.</p>
    <div class="rw-cta">
      <a class="btn" href={REWARDS_URL} target="_blank" rel="noopener">Join Rewards</a>
      <button class="btn-ghost" id="rwApp" data-ios={APP_IOS} data-android={APP_ANDROID}>Get the App</button>
    </div>
    <div class="rw-stores" id="rwStores" hidden>
      <span>Download:</span>
      <a href={APP_IOS} target="_blank" rel="noopener">App Store</a>
      <a href={APP_ANDROID} target="_blank" rel="noopener">Google Play</a>
    </div>
  </section>

  <section class="rw-how" data-nav-theme="light">
    <p class="rw-script">Here's how it works:</p>
    <div class="rw-point">$1 = 1 Point</div>

    <div class="rw-perks">
      {perks.map((x) => (
        <div class="rw-perk">
          <h3>{x.h}</h3>
          <p>{x.p}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="rw-earn">
    <h2>A few things your<br />points can earn</h2>
    <div class="rw-earn-grid">
      {earn.map((e) => (
        <div class="rw-earn-item">
          <div class="ei-name">{e.item}</div>
          <div class="ei-pts">{e.points} points</div>
        </div>
      ))}
    </div>
    <a class="btn rw-bigcta" href={REWARDS_URL} target="_blank" rel="noopener">Join Rewards</a>
    <p class="rw-foot">Or grab the app — same points, exclusive offers.</p>
  </section>
</Base>

<style>
  .rw-banner{
    background:var(--coral);color:#fff;text-align:center;font-family:var(--font-body);
    font-weight:700;text-transform:uppercase;letter-spacing:.14em;font-size:clamp(14px,2.2vw,20px);
    padding:18px 16px;
  }

  .rw-hero{background:var(--navy);color:var(--cream);text-align:center;padding:64px 24px 56px}
  .rw-join{font-family:var(--font-body);font-weight:700;text-transform:uppercase;letter-spacing:.34em;font-size:14px;color:var(--coral);margin-bottom:6px}
  .rw-title{line-height:.86}
  .rw-aunt{display:block;font-family:var(--font-display);color:#fff;font-size:clamp(44px,10vw,104px)}
  .rw-buddies{display:block;font-family:var(--font-script);color:var(--coral);font-size:clamp(46px,11vw,118px);line-height:.7;margin-top:-.12em}
  .rw-lead{max-width:560px;margin:22px auto 0;color:#cfd3e6;font-size:17px;line-height:1.6;font-weight:500}
  .rw-cta{margin-top:30px;display:flex;gap:14px;justify-content:center;flex-wrap:wrap}
  .rw-stores{margin-top:18px;display:flex;gap:12px;justify-content:center;align-items:center;flex-wrap:wrap;color:#aab0d0;font-size:13px}
  .rw-stores[hidden]{display:none}
  .rw-stores a{font-weight:700;color:#fff;text-decoration:underline;text-underline-offset:3px}
  .rw-stores a:hover{color:var(--mint)}

  .rw-how{background:var(--navy);color:var(--cream);text-align:center;padding:8px 24px 72px}
  .rw-script{font-family:var(--font-script);color:var(--mint);font-size:clamp(28px,5vw,44px);margin-bottom:24px}
  .rw-point{
    display:inline-block;font-family:var(--font-display);color:var(--coral);font-size:clamp(40px,8vw,80px);
    line-height:1;padding:22px 54px;border:4px solid var(--coral);border-radius:var(--radius-pill);
  }
  .rw-perks{max-width:var(--maxw);margin:56px auto 0;display:grid;grid-template-columns:repeat(3,1fr);gap:26px}
  .rw-perk{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:16px;padding:26px;text-align:left}
  .rw-perk h3{font-family:var(--font-display);color:var(--mint);font-size:21px;margin-bottom:8px;line-height:1}
  .rw-perk p{color:#c4c9e0;font-size:14px;line-height:1.55}
  @media(max-width:760px){ .rw-perks{grid-template-columns:1fr} }

  .rw-earn{background:var(--cream);text-align:center;padding:76px 24px 90px}
  .rw-earn h2{font-family:var(--font-display);color:var(--navy);font-size:clamp(32px,6vw,58px);line-height:.92;margin-bottom:36px}
  .rw-earn-grid{max-width:760px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
  .rw-earn-item{background:#fff;border:1px solid #efe7da;border-radius:16px;padding:30px 16px;box-shadow:0 10px 26px rgba(60,30,20,.06)}
  .ei-name{font-family:var(--font-display);color:var(--coral);font-size:clamp(24px,3.4vw,34px);line-height:1}
  .ei-pts{margin-top:8px;font-family:var(--font-body);font-weight:700;text-transform:uppercase;letter-spacing:.1em;font-size:13px;color:#3a8079}
  @media(max-width:600px){ .rw-earn-grid{grid-template-columns:1fr;max-width:340px} }
  .rw-bigcta{margin-top:44px;font-size:15px;padding:17px 44px}
  .rw-foot{margin-top:14px;color:var(--ink-soft);font-size:13px}
</style>

<script>
  const app = document.getElementById("rwApp") as HTMLButtonElement | null;
  const stores = document.getElementById("rwStores") as HTMLElement | null;
  app?.addEventListener("click", () => {
    const ua = navigator.userAgent || "";
    const isIOS = /iPad|iPhone|iPod/.test(ua) || (navigator.platform === "MacIntel" && (navigator as any).maxTouchPoints > 1);
    const isAndroid = /Android/.test(ua);
    if (isIOS) window.open(app.dataset.ios, "_blank", "noopener");
    else if (isAndroid) window.open(app.dataset.android, "_blank", "noopener");
    else if (stores) stores.hidden = false;
  });
</script>
